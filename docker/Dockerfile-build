# syntax=docker/dockerfile:1
# Builds CVMFS packages inside a pre-built builddeps image and exports them.
#
# Requires BuildKit. Typical invocation (from the cvmfs source tree):
#
#   DOCKER_BUILDKIT=1 docker build \
#       --build-arg BUILDDEPS_IMAGE=debian11-x86_64-cvmfs-builddeps \
#       --build-arg PLATFORM_TAG=debian11-x86_64-42 \
#       --build-arg NIGHTLY_NUMBER=42 \
#       --output type=local,dest=./build/debian11_x86_64 \
#       --target export \
#       -f <ci-scripts>/docker/Dockerfile-build \
#       .
#
# Omit --build-arg NIGHTLY_NUMBER for a release build.
#
# Caches are keyed on PLATFORM_TAG so that parallel platform builds on the
# same host use separate ccache and externals stores without interference.

ARG BUILDDEPS_IMAGE
FROM ${BUILDDEPS_IMAGE} AS builder

ARG PLATFORM_TAG
ARG NIGHTLY_NUMBER=

ENV CMAKE_CXX_COMPILER_LAUNCHER=ccache

RUN mkdir -p /home/sftnight/buildpackage

# The builddeps image bootstraps a recent cmake into
# /root/.cache/cvmfs_externals_install/.  The build step below cache-mounts
# that directory (to persist compiled C++ externals between builds), which
# shadows the bootstrapped cmake.  Copy it to /usr/local/bin so it stays
# available regardless of the cache mount contents.
RUN cmake_bin="$(find /root/.cache/cvmfs_externals_install \
        -name cmake -type f -executable 2>/dev/null | head -1)" && \
    if [ -n "$cmake_bin" ]; then \
        cp "$cmake_bin" /usr/local/bin/cmake; \
    fi && \
    go_bin="$(find /root/.cache/cvmfs_externals_install \
        -name go -type f -executable 2>/dev/null | head -1)" && \
    if [ -n "$go_bin" ]; then \
        go_root="$(dirname "$go_bin")/.."; \
        cp -a "$go_root" /usr/local/go; \
        ln -sf /usr/local/go/bin/go /usr/local/bin/go; \
        ln -sf /usr/local/go/bin/gofmt /usr/local/bin/gofmt; \
    fi

# Build the main cvmfs package.
# ccache and externals caches are persisted on the host between builds and
# keyed on PLATFORM_TAG to prevent cross-platform interference.
RUN --mount=type=bind,source=.,target=/cvmfs,readonly \
    --mount=type=cache,target=/root/.cache/ccache,id=ccache-${PLATFORM_TAG},sharing=locked \
    --mount=type=cache,target=/root/.cache/cvmfs_externals_install,id=externals-${PLATFORM_TAG},sharing=locked \
    /cvmfs/ci/build_package.sh \
        /cvmfs \
        /home/sftnight/buildpackage \
        cvmfs \
        ${NIGHTLY_NUMBER}

# ── Export stage ──────────────────────────────────────────────────────────────
# Copy packages into a scratch image so that --output extracts only the
# build artifacts, nothing else.
FROM scratch AS export
COPY --from=builder /home/sftnight/buildpackage/        /packages/
