# syntax=docker/dockerfile:1
# Minimal image for creating a CVMFS source tarball.
# Provides git and a recent Go toolchain; the cvmfs source tree and output
# directory are bind-mounted at runtime.
#
# Build:
#   docker build -t cvmfs-sourcetarball \
#       -f <ci-scripts>/docker/Dockerfile-sourcetarball \
#       <ci-scripts>/docker
#
# Run:
#   docker run --rm \
#       -e GOTOOLCHAIN=auto \
#       -e GOPROXY=http://cvm-gomod-proxy1.cern.ch:3000 \
#       -v <cvmfs-src>:/cvmfs:ro \
#       -v <output-dir>:/build \
#       cvmfs-sourcetarball \
#       /cvmfs/ci/build_cvmfs_sourcetarball.sh /cvmfs /build [<nightly_number>]

FROM docker.io/debian:12-slim

ARG GOVERSION=1.24.2

RUN apt-get -y update && apt-get -y install --no-install-recommends \
        ca-certificates \
        curl \
        git \
    && rm -rf /var/lib/apt/lists/*

RUN curl -fsSL "https://go.dev/dl/go${GOVERSION}.linux-amd64.tar.gz" \
    | tar -C /usr/local -xz

ENV PATH="/usr/local/go/bin:${PATH}"
ENV GOTOOLCHAIN=auto
